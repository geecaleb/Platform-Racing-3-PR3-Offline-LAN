      }
      
      /*
       * Calculate the XP needed for ranking up - copied from ExpBar class
       */
      private function calculateExpForRankUp(rank:int) : Number
      {
         return rank == 0 ? 1 : Math.floor(30 * Math.pow(1.25, rank - 1));
      }
