                                currentRank, // Use current rank which may have increased
                                expBar.width
                            );
                            
                            // Position it in the same place
                            updatedExpBar.x = expBar.x;
                            updatedExpBar.y = expBar.y;
                            
                            // Remove old bar and add new one
                            if (contains(expBar)) {
                                removeChild(expBar);
                            }
                            addChild(updatedExpBar);
                            expBar = updatedExpBar;
                            
                            // Update the XP text to reflect server values
                            if (xpText != null) {
                                // Move xpText to front if needed
                                if (contains(xpText)) {
                                    setChildIndex(xpText, numChildren - 1);
                                }
                            }
                        }
                        
                        // Display rank up popup if rank up occurred
                        if (didRankUp) {
                            addPopup(new RankUpPopup(currentRank));
                        }
                    }
                } catch (e:Error) {
                    // Silent error handling - no logging
                }
            }
         }
      }
      
