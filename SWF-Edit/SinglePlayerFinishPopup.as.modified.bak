      public function saveRunCallback(param1:XML, param2:String) : void
      {
         if(param2 != "")
         {
            addPopup(new MessagePopup("Your run could not be saved. " + param2));
         }
         else
         {
            this.checkHatRewards();
            
            // Handle XP update from server
            if (param1 != null && !SocketManager.socket.me.vars.guest)
            {
                var serverXP:Number = 0;
                var didRankUp:Boolean = false;
                var initialRank:Number = SocketManager.socket.me.vars.rank; // Store initial rank for comparison
                
                try {
                    // First try to access XP through Row.xp_earned
                    if (param1.hasOwnProperty("Row") && param1.Row.hasOwnProperty("xp_earned")) {
                        serverXP = Number(param1.Row.xp_earned);
                    } 
                    // Try direct access if the above path fails
                    else if (param1.hasOwnProperty("xp_earned")) {
                        serverXP = Number(param1.xp_earned);
                    }
                    
                    // Check if the response contains rank information
                    var serverRank:Number = 0;
                    if (param1.hasOwnProperty("Row") && param1.Row.hasOwnProperty("rank")) {
                        serverRank = Number(param1.Row.rank);
                        if (serverRank > initialRank) {
                            didRankUp = true;
                        }
                    } 
                    // Try direct access if the above path fails
                    else if (param1.hasOwnProperty("rank")) {
                        serverRank = Number(param1.rank);
                        if (serverRank > initialRank) {
                            didRankUp = true;
                        }
                    }
                    
                    // Update SocketManager with server XP - this ensures UI consistency
                    if (serverXP > 0) {
                        // Update the local XP variable to match server
                        SocketManager.socket.me.vars.exp = serverXP;
                        
                        // Update rank if provided by server
                        if (serverRank > 0) {
                            SocketManager.socket.me.vars.rank = serverRank;
                        }
                        // Otherwise, try to use checkForRankUp as fallback
                        else if (SocketManager.socket.me != null && 
                            SocketManager.socket.me.hasOwnProperty("checkForRankUp")) {
                            // This will update the rank internally if needed
                            didRankUp = SocketManager.socket.me.checkForRankUp() || didRankUp;
                        }
                        
                        // Get current rank after possible rank up
                        var currentRank:Number = SocketManager.socket.me.vars.rank;
                        
                        // Force rank-up check again by comparing initial and current rank
                        if (currentRank > initialRank) {
                            didRankUp = true;
                        }
                        
                        // If ranked up, show animation and set flags
                        if (didRankUp) {
                            this.leveledUp = true;
                            CustomizePopup.leveledUp = true;
                            
                            // Play sound effect for level up
                            Sounds.startSound(new CheerSound(), 1);
                            
                            // Show level up animation if the graphic has it
